# Keep the build context small and the image reproducible — only ship what the
# runtime needs (src + project metadata). Everything else is dev/CI/docs cruft.
.git
.github/
.venv/
venv/
env/

__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Not needed at runtime
tests/
claude_docs/
docs/
REVIEW.md

# Secrets / local env (never bake into an image)
.env
.env.*
!.env.example

.DS_Store
Thumbs.db
*.swp
