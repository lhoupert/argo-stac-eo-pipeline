{
  "name": "eo-ladder",
  "build": { "dockerfile": "Dockerfile" },

  // Docker-in-Docker so kind can create its cluster *inside* the dev container — this is what makes
  // "reopen in container" able to run rungs 1–4, not just rung 0.
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // Install the project (and dev tools) once the container is up.
  "postCreateCommand": "uv sync",

  // The demo's port-forwards (make ui / make browse) are auto-forwarded by VS Code; these labels
  // make them readable in the Ports panel. argo-server runs with --secure=false (plain HTTP), so
  // 2746 needs no special protocol — HTTP is VS Code's default.
  "portsAttributes": {
    "2746": { "label": "Argo Workflows UI", "onAutoForward": "silent" },
    "8081": { "label": "STAC API",          "onAutoForward": "silent" },
    "8082": { "label": "stac-browser UI",   "onAutoForward": "openBrowser" },
    "9100": { "label": "MinIO assets",      "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "extensions": ["charliermarsh.ruff", "ms-python.python", "redhat.vscode-yaml"],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/2026_foss4geurope/.venv/bin/python"
      }
    }
  },

  // kind needs a few extra capabilities; the cluster's API server is reachable on the host network.
  "runArgs": ["--init"],

  "remoteUser": "vscode"
}
