# Copy to .env and adjust. NEVER commit real secrets — .env is gitignored.

# STAC logbook API. Unset/empty disables registration (rung 0 has no catalog).
STAC_URL=

# Data source backend: synthetic (default, offline) | earthsearch (real Sentinel-2)
SOURCE_TYPE=synthetic

# Collection to ingest: synthetic-aurora-veil | synthetic-tidal-glass
COLLECTION=synthetic-aurora-veil

# S3 / MinIO sink
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=eo-assets
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# Demo knobs
FAIL_ONCE=0          # inject one transient failure then succeed (rung-1 retry clip)
INGEST_SLEEP=0       # per-item sleep (seconds) simulating IO cost for the fan-out demo

# Public HTTP base for asset hrefs in the STAC catalog (enables stac-browser thumbnail previews).
# Unset keeps s3:// hrefs (all in-cluster paths still work). Set when using `make browse`.
# ASSET_BASE_URL=http://localhost:9100/eo-assets
